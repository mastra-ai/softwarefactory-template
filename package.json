{
  "name": "mastra-factory",
  "version": "0.1.0",
  "description": "Mastra Factory: an agent-powered software delivery environment. Intake GitHub/Linear issues, work them with coding agents, and ship pull requests — all from your own deployable web app.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "mastra factory dev --dir src/mastra",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "check": "tsc --noEmit && tsc --noEmit -p src/web/ui/tsconfig.json",
    "build": "mastra build --dir src/mastra",
    "start": "varlock run -- mastra start",
    "deploy": "mastra deploy"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
