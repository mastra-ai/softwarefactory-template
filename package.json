{
  "name": "mastra-software-factory",
  "version": "0.1.0",
  "description": "Mastra Software Factory: an agent-powered software delivery environment. Intake GitHub/Linear issues, work them with coding agents, and ship pull requests — all from your own deployable web app.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "build": "npm run build:ui && npm run build:server",
    "build:ui": "vite --config src/web/vite.config.ts build",
    "build:server": "mastra build --dir src/mastra",
    "start": "varlock run -- mastra start",
    "deploy": "npm run build && node scripts/validate-output.mjs && mastra deploy --skip-build",
    "check": "tsc --noEmit && tsc --noEmit -p src/web/ui/tsconfig.json"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@mastra/auth-workos": "^1.6.3",
    "@mastra/client-js": "^1.33.0-alpha.4",
    "@mastra/code-sdk": "^0.2.0-alpha.4",
    "@mastra/core": "^1.52.0-alpha.4",
    "@mastra/hono": "^1.5.8-alpha.4",
    "@mastra/libsql": "^1.16.0",
    "@mastra/pg": "^1.16.1-alpha.0",
    "@mastra/playground-ui": "^42.0.0-alpha.4",
    "@mastra/railway": "^0.3.1",
    "@mastra/react": "^1.2.6-alpha.4",
    "@mastra/redis-streams": "^0.3.0",
    "@octokit/auth-app": "^8.0.0",
    "@octokit/rest": "^22.0.1",
    "@tanstack/react-query": "^5.90.21",
    "better-auth": "^1.6.23",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.12.8",
    "lucide-react": "^0.474.0",
    "marked": "^15.0.0",
    "pg": "^8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "^7.13.1",
    "shiki": "^1.29.2",
    "zod": "^4.3.6",
    "react-is": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "22.20.1",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "concurrently": "^9.1.2",
    "mastra": "^1.19.1-alpha.4",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "varlock": "^1.9.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
