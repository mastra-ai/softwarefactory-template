# MastraCode Web environment schema for Varlock.
# Every section is optional: when the vars for a feature are absent, that
# feature is a no-op and the web app behaves exactly as before.
# @defaultRequired=false
# @defaultSensitive=true
# ---

# ---------------------------------------------------------------------------
# Browser-facing origin
# ---------------------------------------------------------------------------

# The public origin the browser uses to reach the app. This is the single
# source of truth for ALL OAuth callback URLs:
#   - WorkOS:  <MASTRACODE_PUBLIC_URL>/auth/callback
#   - GitHub:  <MASTRACODE_PUBLIC_URL>/auth/github/callback
#   - Linear:  <MASTRACODE_PUBLIC_URL>/auth/linear/callback
# In dev the SPA is served by Vite on :5173 and proxies to the server (:4111),
# so set this to the SPA origin (http://localhost:5173). Falls back to the
# server bind when unset. Restart `web:dev` after changing this — varlock
# re-reads .env on each start.
# @public @type=url
MASTRACODE_PUBLIC_URL=
# Comma-separated origins allowed for credentialed cross-origin requests; only
# needed when the SPA is hosted separately from the API server.
# @public
MASTRACODE_ALLOWED_ORIGINS=
# Explicit path to the built SPA (a dir containing index.html). In production
# the built SPA is served same-origin at `/` by the API server. It is
# auto-located: MASTRACODE_UI_DIST, then `ui/` next to the server bundle
# (mastra build copies the vite output there via the Mastra entry's public/
# dir), then `src/mastra/public/ui` under cwd.
# @public
MASTRACODE_UI_DIST=

# ---------------------------------------------------------------------------
# Mastra platform auth (highest precedence)
# When MASTRA_SHARED_API_URL is set, this instance defers all identity to a
# Mastra platform API (e.g. https://platform.mastra.ai/v1). No WorkOS/WorkOS
# secrets are needed here — the platform owns them. Takes precedence over
# WORKOS_* and BETTER_AUTH_SECRET below, so a platform-deferred deployment
# never falls back to its own credentials by accident.
# ---------------------------------------------------------------------------

# Base URL of the Mastra platform API's `/v1` root (e.g.
# https://platform.mastra.ai/v1 or http://localhost:3010/v1 for local dev
# against a locally-running platform API). Also used by zero-argument
# PlatformGithubIntegration and PlatformLinearIntegration.
# @public @type=url
MASTRA_SHARED_API_URL=
# Optional: pin this deployment to a specific WorkOS organization. Users
# whose memberships don't include this org are rejected. Leave unset for
# multi-org deployments.
# @public
MASTRA_ORGANIZATION_ID=
# Optional: parent cookie domain (e.g. `.mastra.cloud`) for the sealed
# session cookie this deployment sets after callback. Auto-detected from
# MASTRA_SHARED_API_URL for `*.mastra.ai` hosts; otherwise the cookie is
# host-only (fine for localhost dev on different ports).
# @public
MASTRA_COOKIE_DOMAIN=

# ---------------------------------------------------------------------------
# Mastra Platform integrations and sandbox
# PlatformGithubIntegration and PlatformLinearIntegration are zero-argument
# integrations. They use MASTRA_SHARED_API_URL and this Platform secret key.
# PlatformSandbox is selected automatically only when MASTRA_PLATFORM_SECRET_KEY,
# MASTRA_PROJECT_ID, and MASTRA_ENVIRONMENT_ID are all set.
# ---------------------------------------------------------------------------

# Required when a Platform integration is instantiated or when PlatformSandbox
# is selected.
MASTRA_PLATFORM_SECRET_KEY=
# Deprecated alias for MASTRA_PLATFORM_SECRET_KEY.
MASTRA_PLATFORM_ACCESS_TOKEN=
# Required for PlatformSandbox auto-selection.
# @public
MASTRA_PROJECT_ID=
# Required for PlatformSandbox auto-selection.
# @public
MASTRA_ENVIRONMENT_ID=
# Optional PlatformSandbox workspace proxy URL. Defaults to the hosted proxy.
# @public @type=url
MASTRA_WORKSPACE_PROXY_URL=
# GitHub event polling is enabled by default. Set false to disable it.
# @public @type=enum("", "true", "false")
MASTRA_PLATFORM_GITHUB_POLLING_ENABLED=
# Optional positive polling interval in milliseconds. Defaults to 5000.
# @public @type=string(matches="^(|[1-9][0-9]*)$")
MASTRA_PLATFORM_GITHUB_POLLING_INTERVAL_MS=

# ---------------------------------------------------------------------------
# WorkOS auth
# When WORKOS_API_KEY and WORKOS_CLIENT_ID are set, every route requires a
# signed-in user (hosted login + encrypted session). This is a prerequisite
# for the GitHub projects feature below.
# ---------------------------------------------------------------------------

WORKOS_API_KEY=
# @public @required=not(isEmpty($WORKOS_API_KEY))
WORKOS_CLIENT_ID=
# Optional — defaults to <MASTRACODE_PUBLIC_URL>/auth/callback. Must match an
# allowed redirect URI in the WorkOS dashboard.
# For local dev: http://localhost:5173/auth/callback
# @public @type=url
WORKOS_REDIRECT_URI=
# Optional (recommended in prod): 32+ char secret to seal session cookies.
WORKOS_COOKIE_PASSWORD=
# On first authenticated use, bootstrap a personal WorkOS organization for
# users who have none, so org-scoped features (GitHub connect) work without
# hand-creating an org. Enabled by default. Set to 0 for deployments that
# provision orgs themselves (e.g. SSO). Requires the WorkOS API key to have
# permission to create organizations and memberships.
# @public @type=enum("", "0", "1")
MASTRACODE_BOOTSTRAP_PERSONAL_ORG=

# ---------------------------------------------------------------------------
# Application database
# Single Postgres for the app: holds Mastra agent state (threads, messages,
# memory, recall vectors) AND — when the GitHub App block below is configured
# — GitHub project/installation metadata. When unset, agent state falls back
# to a local libSQL file (bare local dev only). For local dev, run
# `docker compose up -d` from the package root (see docker-compose.yml); the
# container matches postgres://user:pass@localhost:54329/mastracode_web.
# On the Mastra platform this is populated automatically by the managed
# env-var sync when a Neon (or other) database is attached to the project.
# ---------------------------------------------------------------------------

DATABASE_URL=
# Deprecated alias for DATABASE_URL. Honored as a fallback for existing
# checkouts; new setups should use DATABASE_URL instead.
APP_DATABASE_URL=

# ---------------------------------------------------------------------------
# GitHub projects
# When the GitHub App variables are set AND WorkOS auth is enabled, signed-in
# users can install the GitHub App, pick repositories, and turn each repo into
# a project. Repo and project metadata persist in the application Postgres
# above (DATABASE_URL).
#
# The GitHub OAuth callback URL is always derived from MASTRACODE_PUBLIC_URL
# (/auth/github/callback) — there is no separate redirect env var. Register
# this exact URL in the GitHub App's "Callback URL" field (Settings → GitHub
# Apps → your app → General → Callback URL).
# ---------------------------------------------------------------------------

# @public
GITHUB_APP_ID=
# PEM contents, e.g. "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# @required=not(isEmpty($GITHUB_APP_ID))
GITHUB_APP_PRIVATE_KEY=
# @public @required=not(isEmpty($GITHUB_APP_PRIVATE_KEY))
GITHUB_APP_CLIENT_ID=
# @required=not(isEmpty($GITHUB_APP_CLIENT_ID))
GITHUB_APP_CLIENT_SECRET=
# @public @required=not(isEmpty($GITHUB_APP_CLIENT_SECRET))
GITHUB_APP_SLUG=
# Secret for install/uninstall webhooks. Also used to sign GitHub OAuth/install
# state. REQUIRED for multi-replica deployments: without an explicit secret
# (this or WORKOS_COOKIE_PASSWORD), state is signed with a per-process random
# key and callbacks fail on a replica that did not sign the state.
GITHUB_APP_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Model providers
# API keys for the agent's model providers. Loaded from this file by the
# code SDK on boot; keys can also be added/managed at runtime from the
# web UI (Settings › Models). At least one provider key (or a stored
# credential) is needed for agents to run.
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Linear intake
# When BOTH Linear OAuth vars are set AND web auth is enabled AND the app
# database is configured, orgs can connect a Linear workspace and pull issues
# into the intake board. Setting only one of the two vars is a boot error
# (all-or-nothing per integration).
#
# The Linear OAuth callback URL is derived from MASTRACODE_PUBLIC_URL
# (/auth/linear/callback) — register that exact URL in the Linear OAuth app.
# ---------------------------------------------------------------------------

# Keep this dependency one-way: reciprocal @required annotations form a
# Varlock dependency cycle. Runtime envGroup validation enforces the other
# direction and reports a partial Linear configuration as a boot error.
# @public @required=not(isEmpty($LINEAR_CLIENT_SECRET))
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Distributed event bus (optional)
# When set, events (streams, workflows, signals) ride Redis Streams so
# multiple web server processes share one event bus. Unset for single-process
# local dev. docker-compose.yml provides redis://localhost:63799.
# ---------------------------------------------------------------------------

REDIS_URL=

# ---------------------------------------------------------------------------
# Sandbox provider (repo materialization)
# GitHub-backed projects are materialized (cloned) into a sandbox on open. The
# provider is selected automatically: if a Railway token is set we use an
# isolated cloud VM per project; otherwise we fall back to a LOCAL provider
# that runs git directly on the server host. So repos can always be opened
# with no extra wiring. The sandbox must have `git` and `gh` (the GitHub CLI)
# and outbound access to github.com; `gh` is only needed to open pull requests.
#
# WARNING: the local provider has NO tenant isolation — every project's git
# runs as the server process on the shared host filesystem. It is intended for
# single-user local development only; configure Railway for shared
# multi-tenant deployments.
# ---------------------------------------------------------------------------

# @required=eq($MASTRACODE_SANDBOX_PROVIDER, "railway")
RAILWAY_API_TOKEN=
# @public
RAILWAY_ENVIRONMENT_ID=
# Force a specific provider. Leave unset to auto-select: railway when
# RAILWAY_API_TOKEN is set, else the non-isolated local provider (see the
# warning above). Selecting "railway" without a token fails at boot.
# @public @type=enum("", "railway", "local")
MASTRACODE_SANDBOX_PROVIDER=
# Checkout base inside remote sandboxes (nested owner/name per repo), default
# /workspace. LocalSandbox ignores this in-sandbox path and always uses
# MASTRACODE_LOCAL_SANDBOX_ROOT on the host.
# @public
MASTRACODE_SANDBOX_WORKDIR=/workspace
# Host root for LocalSandbox checkouts (default ~/.mastracode/web/sandboxes);
# only used when MASTRACODE_SANDBOX_PROVIDER=local.
# @public
MASTRACODE_LOCAL_SANDBOX_ROOT=
# Idle teardown window in minutes (default 30); the next open re-provisions
# automatically if the VM was stopped.
# @public @type=string(matches="^(|[1-9][0-9]*)$")
MASTRACODE_SANDBOX_IDLE_MINUTES=30
# Per-replica cap on concurrently live sandboxes. New provisioning beyond this
# returns an actionable error; 0 / unset means unlimited.
# @public @type=string(matches="^(|[0-9]+)$")
MASTRACODE_MAX_SANDBOXES=

# ---------------------------------------------------------------------------
# Multi-replica deployment
# ---------------------------------------------------------------------------

# Set to 0 to disable the Postgres advisory-lock layer used to serialize
# per-(project,user) git write operations across replicas. When enabled
# (default), it requires DATABASE_URL. Use 0 for single-process local dev.
# @public @type=enum("", "0", "1")
MASTRACODE_DISTRIBUTED_LOCK=

# ---------------------------------------------------------------------------
# Local development tools
# ---------------------------------------------------------------------------

# Set to exactly "true" to load react-grab in the Vite development server;
# empty means off.
# @public @type=enum("", "true")
VITE_REACT_GRAB=
